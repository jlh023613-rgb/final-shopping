<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.shopping.mapper.AdminMapper">
    <select id="findByUsername" resultType="com.example.shopping.entity.Admin">
        SELECT * FROM admins WHERE username = #{username}
    </select>
</mapper>
